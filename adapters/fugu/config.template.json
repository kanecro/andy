{
  "name": "andy",
  "version": "0.2.0",
  "entrypoint": "AGENTS.md",
  "entrypoints": {
    "canonical": "AGENTS.md",
    "claude": "CLAUDE.md",
    "gemini": "GEMINI.md"
  },
  "core": {
    "principles": "core/principles.md",
    "workflows": "core/workflows",
    "roles": "core/roles",
    "policies": "core/policies",
    "skills": "core/skills",
    "artifactSchemas": "core/artifact-schemas",
    "guardrails": "core/guardrails",
    "commandRouter": "core/workflows/command-router.md",
    "rulePrecedence": "core/policies/rule-precedence-policy.md",
    "immutableRules": "core/policies/immutable-rules.md",
    "projectOverrides": "core/policies/project-overrides-policy.md",
    "harnessResolution": "core/policies/harness-resolution-policy.md"
  },
  "commands": {
    "brainstorm": "core/workflows/brainstorm.md",
    "spec": "core/workflows/spec.md",
    "implement": "core/workflows/implement.md",
    "review": "core/workflows/review.md",
    "test": "core/workflows/test.md",
    "compound": "core/workflows/compound.md",
    "ship": "core/workflows/ship.md"
  },
  "modelSelection": {
    "mode": "delegate_to_runtime",
    "useCapabilityProfiles": true,
    "avoidHardcodedModelNames": true
  },
  "installation": {
    "defaultCodexHome": "~/.codex",
    "harnessSymlink": "~/.codex/harnesses/andy",
    "defaultCodexEntrypoint": "~/.codex/AGENTS.md",
    "activeHarnessSymlink": "~/.codex/active-harness",
    "configTemplateSymlink": "~/.codex/andy.config.template.json",
    "configFile": "~/.codex/andy.config.json",
    "optionalGlobalShims": {
      "claude": "~/.claude/CLAUDE.md",
      "gemini": "~/.gemini/GEMINI.md"
    },
    "globalCommands": {
      "codex": "~/.codex/prompts/*.md",
      "claude": "~/.claude/commands/*.md",
      "gemini": "~/.gemini/commands/*.toml"
    },
    "commandAdapters": {
      "codex": "adapters/codex/prompts",
      "claude": "adapters/claude/commands",
      "gemini": "adapters/gemini/commands"
    },
    "commandCatalog": "adapters/commands/catalog.json",
    "commandGenerator": "scripts/generate-commands.py"
  },
  "templates": {
    "project": "templates/project"
  }
}
